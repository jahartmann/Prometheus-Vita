# =============================================================================
# Prometheus - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=prometheus
POSTGRES_PASSWORD=changeme_db_password
POSTGRES_DB=prometheus
POSTGRES_SSLMODE=prefer
POSTGRES_MAX_CONNS=20

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_DB=0

# -----------------------------------------------------------------------------
# Backend Server
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# LOG_LEVEL  : debug | info (default) | warn | error
# LOG_FORMAT : json (default, machine-parseable) | text (human-friendly)
LOG_LEVEL=info
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme_jwt_secret_at_least_32_characters_long

# Access token lifetime in minutes
JWT_ACCESS_EXPIRY_MINUTES=15

# Refresh token lifetime in hours
JWT_REFRESH_EXPIRY_HOURS=168

# -----------------------------------------------------------------------------
# Encryption (AES-256-GCM for sensitive data like API tokens)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32 (must be exactly 64 hex chars = 32 bytes)
ENCRYPTION_KEY=changeme_encryption_key_exactly_64_hex_characters_long_here

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Must include the ORIGIN the browser uses to open the app. When accessing the
# app directly by IP (not localhost), add it here too, e.g.:
#   http://192.168.60.173:3000
# The live-metrics/logs WebSocket connects from the browser straight to the
# backend (:8080) and is rejected if the browser origin is not listed here.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080

# -----------------------------------------------------------------------------
# LLM / Local AI
# -----------------------------------------------------------------------------
# Docker Compose with profile "ai-local": http://ollama:11434
# Backend started locally on the host: http://localhost:11434
LLM_OLLAMA_URL=http://ollama:11434
# Default model for the agent. Must support tool calling — Llama 3 (without .1)
# does NOT support tool calling and will make the agent appear "dumb".
# Recommended models by hardware tier:
#   minimal/edge:  llama3.2:3b
#   light (8GB):   llama3.1:8b   ← safe default
#   standard:      qwen2.5:14b
#   pro:           qwen2.5:32b
#   enterprise:    llama3.3:70b or qwen2.5:72b
LLM_DEFAULT_MODEL=llama3.1:8b

# Optional remote providers. Leave empty unless you explicitly configure them.
LLM_OPENAI_KEY=
LLM_OPENAI_URL=
LLM_ANTHROPIC_KEY=

# -----------------------------------------------------------------------------
# Admin Seed User
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# Browser/client API base. Docker Compose uses the backend service name internally,
# local browser development usually uses http://localhost:8080.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Live WebSocket (metrics + logs). The Next.js proxy CANNOT forward WebSocket
# upgrades, so the browser connects to the backend directly. By default the
# frontend derives the backend WS from the current host on port 8080
# (ws://<host>:8080), which works for the standard compose setup (frontend
# :3000 + backend :8080). Behind the TLS/Caddy reverse-proxy profile it works
# same-origin (wss://<domain>). Set this only for non-default topologies:
# NEXT_PUBLIC_WS_URL=ws://192.168.60.173:8080

# -----------------------------------------------------------------------------
# Reverse proxy / TLS (only when running `docker compose --profile tls up`)
# -----------------------------------------------------------------------------
# Public hostname users open in the browser.
PROMETHEUS_HOSTNAME=localhost
# `tls_internal` uses Caddy's self-signed CA (good for LAN/dev).
# Set to `tls_public` and configure CADDY_ACME_EMAIL to enable Let's Encrypt
# (needs a real public DNS record and port 80 reachable for ACME challenge).
PROMETHEUS_TLS_SNIPPET=tls_internal
CADDY_ACME_EMAIL=admin@localhost

# -----------------------------------------------------------------------------
# Postgres backups (only when running `docker compose --profile backup up`)
# -----------------------------------------------------------------------------
# Seconds between backups. 86400 = 24h.
BACKUP_INTERVAL_S=86400
# Days to keep dumps before pruning.
BACKUP_RETENTION_DAYS=14
