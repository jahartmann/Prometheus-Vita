# =============================================================================
# Prometheus - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=prometheus
POSTGRES_PASSWORD=changeme_db_password
POSTGRES_DB=prometheus
POSTGRES_SSLMODE=prefer
POSTGRES_MAX_CONNS=20

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_DB=0

# -----------------------------------------------------------------------------
# Backend Server
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme_jwt_secret_at_least_32_characters_long

# Access token lifetime in minutes
JWT_ACCESS_EXPIRY_MINUTES=15

# Refresh token lifetime in hours
JWT_REFRESH_EXPIRY_HOURS=168

# -----------------------------------------------------------------------------
# Encryption (AES-256-GCM for sensitive data like API tokens)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32 (must be exactly 64 hex chars = 32 bytes)
ENCRYPTION_KEY=changeme_encryption_key_exactly_64_hex_characters_long_here

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080

# -----------------------------------------------------------------------------
# LLM / Local AI
# -----------------------------------------------------------------------------
# Docker Compose with profile "ai-local": http://ollama:11434
# Backend started locally on the host: http://localhost:11434
LLM_OLLAMA_URL=http://ollama:11434
LLM_DEFAULT_MODEL=llama3

# Optional remote providers. Leave empty unless you explicitly configure them.
LLM_OPENAI_KEY=
LLM_OPENAI_URL=
LLM_ANTHROPIC_KEY=

# -----------------------------------------------------------------------------
# Admin Seed User
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# Browser/client API base. Docker Compose uses the backend service name internally,
# local browser development usually uses http://localhost:8080.
NEXT_PUBLIC_API_URL=http://localhost:8080

# WebSocket endpoints are served by the backend under /api/v1/ws and
# /api/v1/ws/logs. The frontend reaches them through the same API base/proxy.
